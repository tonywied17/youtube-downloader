{
  "name": "youtube-downloader",
  "version": "0.1.6",
  "description": "Modern, lightweight YouTube (and 1000+ site) extractor powered by yt-dlp and ffmpeg",
  "main": "./out/main/index.js",
  "author": "molex",
  "license": "MIT",
  "homepage": "https://github.com/tonywied17/youtube-downloader",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonywied17/youtube-downloader.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:smoke": "electron-vite build && electron ./out/main/index.js --smoke-test",
    "package": "electron-vite build && electron-builder --publish never",
    "package:win": "electron-vite build && electron-builder --win --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "tar": "^7.5.15",
    "youtube-dl-exec": "^3.1.6"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^9.17.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "framer-motion": "^12.39.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.6",
    "zustand": "^5.0.12"
  }
}
