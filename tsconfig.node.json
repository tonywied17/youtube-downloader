{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "tests/main/**/*",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "resolveJsonModule": true,
    "types": ["electron-vite/node", "node"],
    "paths": {
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"]
    }
  }
}
